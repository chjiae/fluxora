# Local infrastructure endpoints. Copy to .env and replace placeholder values.
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432
POSTGRES_DATABASE=fluxora
POSTGRES_USERNAME=fluxora
POSTGRES_PASSWORD=change-me

REDIS_HOST=host.docker.internal
REDIS_PORT=6379
REDIS_PASSWORD=

# 统一入口端口（对外唯一暴露；内部服务不映射端口，仅通过此 nginx 代理）
NGINX_PORT=80

# 后端内部监听端口（仅 Docker 内网可达，不映射宿主）
PLATFORM_PORT=8080
GATEWAY_PORT=8081

# 上游凭证安全配置（V7 引入）：仅用于本地开发的覆盖入口。
# 未设置时使用 application.yml 中标注为「仅本地开发」的测试密钥。
# 生产环境必须设置这三个变量；启动时空缺或格式错误（非 32 字节 Base64）安全拒绝启动。
# 生成命令（PowerShell）：
#   $b=new-object byte[] 32; (new-object Security.Cryptography.RNGCryptoServiceProvider).GetBytes($b); [Convert]::ToBase64String($b)
FLUXORA_CREDENTIAL_MASTER_KEY=
FLUXORA_CREDENTIAL_FINGERPRINT_KEY=
# 单次批量导入凭证数量上限（默认 1000），超出将在导入结果中标记为超限跳过
CREDENTIAL_IMPORT_MAX_COUNT=1000

# Gateway 运行时凭证密钥：必须与 Platform 一致，生产环境使用独立随机 32 字节 Base64 值。
FLUXORA_RUNTIME_CREDENTIAL_KEY=
